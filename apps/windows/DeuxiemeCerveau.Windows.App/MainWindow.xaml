<Window x:Class="DeuxiemeCerveau.Windows.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DeuxiemeCerveau.Windows.App.ViewModels"
        Title="Deuxième Cerveau — Espace de Gestion Personnelle" Height="860" Width="1340"
        Background="{StaticResource BgCanvas}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR NAVIGATION (Modern Slate Sidebar) -->
        <Border Grid.Column="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,1,0">
            <DockPanel Margin="20,28">
                <!-- App Brand & Status Header -->
                <StackPanel DockPanel.Dock="Top" Margin="4,0,0,32">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="12" Background="{StaticResource PrimaryGradient}" Margin="0,0,12,0">
                            <TextBlock Text="🧠" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Deuxième Cerveau" Foreground="{StaticResource TextMain}" FontSize="18" FontWeight="Bold"/>
                            <TextBlock Text="Local-First Engine §6" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation Tabs -->
                <StackPanel DockPanel.Dock="Top">
                    <RadioButton Content="💳   Finances &amp; Solde" Command="{Binding NaviguerFinancesCommand}" IsChecked="True" Style="{StaticResource NavTabButton}"/>
                    <RadioButton Content="📅   Calendrier &amp; Échéances" Command="{Binding NaviguerCalendrierCommand}" Style="{StaticResource NavTabButton}"/>
                    <RadioButton Content="📝   Notes libres" Command="{Binding NaviguerNotesCommand}" Style="{StaticResource NavTabButton}"/>
                    <RadioButton Content="🗑️   Corbeille" Command="{Binding NaviguerCorbeilleCommand}" Style="{StaticResource NavTabButton}"/>
                    <RadioButton Content="⚙️   Réglages &amp; Sync" Command="{Binding NaviguerReglagesCommand}" Style="{StaticResource NavTabButton}"/>
                </StackPanel>

                <!-- Sidebar Footer Status Card -->
                <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom">
                    <Border Style="{StaticResource GlassCard}" Padding="14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,8,0"/>
                                <TextBlock Text="LOCAL-FIRST SECURE" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock Text="Base SQLite &amp; Outbox Actives" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN DASHBOARD CONTENT AREA -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="36">
                <ContentControl Content="{Binding VueCourante}">
                    <ContentControl.Resources>
                        
                        <!-- ================= FINANCES TEMPLATE ================= -->
                        <DataTemplate DataType="{x:Type vm:FinancesViewModel}">
                            <StackPanel>
                                <!-- Dashboard Header -->
                                <Grid Margin="0,0,0,24">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Finances &amp; Vue D'Ensemble" Foreground="{StaticResource TextMain}" FontSize="26" FontWeight="Bold"/>
                                        <TextBlock Text="Tableau de bord financier personnel — données écrites immédiatement en local." Foreground="{StaticResource TextSub}" FontSize="14" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Top 3 Key Metrics Cards Ribbon -->
                                <Grid Margin="0,0,0,28">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Solde de Référence Card -->
                                    <Border Grid.Column="0" Style="{StaticResource GlassCard}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                                <Border Width="28" Height="28" CornerRadius="8" Background="#1E3A34" Margin="0,0,10,0">
                                                    <TextBlock Text="💰" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="SOLDE RÉFÉRENCE (§3.4)" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding SoldeEurosFormatted}" Foreground="{StaticResource SuccessGradient}" FontSize="32" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Total Entrées Card -->
                                    <Border Grid.Column="2" Style="{StaticResource GlassCard}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                                <Border Width="28" Height="28" CornerRadius="8" Background="#1E3A34" Margin="0,0,10,0">
                                                    <TextBlock Text="📈" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="ENTRÉES TOTALES" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding TotalEntreesFormatted}" Foreground="#10B981" FontSize="32" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Total Sorties Card -->
                                    <Border Grid.Column="4" Style="{StaticResource GlassCard}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                                <Border Width="28" Height="28" CornerRadius="8" Background="#3D1E28" Margin="0,0,10,0">
                                                    <TextBlock Text="📉" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="SORTIES TOTALES" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding TotalSortiesFormatted}" Foreground="#EF4444" FontSize="32" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- 2-Column Split: Stream vs Floating Quick Add -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="360"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Column: Transaction Stream -->
                                    <StackPanel Grid.Column="0">
                                        <!-- Search & Filters Ribbon -->
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding RechercheTexte, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Tag="Rechercher une transaction..."/>
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding Transactions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource GlassCard}" Margin="0,6" Padding="18">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Icon Badge -->
                                                            <Border Grid.Column="0" Width="42" Height="42" CornerRadius="12" Background="#28354D" Margin="0,0,16,0">
                                                                <TextBlock Text="💳" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>

                                                            <!-- Title & Type Pill -->
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Titre}" Foreground="{StaticResource TextMain}" FontWeight="Bold" FontSize="15"/>
                                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                                    <Border Background="#2B364A" CornerRadius="6" Padding="8,2" Margin="0,0,8,0">
                                                                        <TextBlock Text="{Binding Type}" Foreground="{StaticResource TextSub}" FontSize="11" FontWeight="SemiBold"/>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding Statut}" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <!-- Amount -->
                                                            <TextBlock Grid.Column="2" Text="{Binding MontantCentimes}" Foreground="{StaticResource TextMain}" FontWeight="Bold" FontSize="18" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- Right Column: Floating Quick Add Panel -->
                                    <Border Grid.Column="2" Style="{StaticResource GlassCard}" VerticalAlignment="Top">
                                        <StackPanel>
                                            <TextBlock Text="⚡ Saisie Rapide" Foreground="{StaticResource TextMain}" FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Text="Écriture immédiate en base SQLite local-first." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,20"/>

                                            <!-- Segmented Type Selector -->
                                            <TextBlock Text="Type de transaction" Foreground="{StaticResource TextSub}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Content="Facture" Command="{Binding ChoisirFactureCommand}" Style="{StaticResource SegmentButton}" Margin="0,0,4,0"/>
                                                <Button Grid.Column="1" Content="Paiement" Command="{Binding ChoisirPaiementCommand}" Style="{StaticResource SegmentButton}" Margin="2,0,2,0"/>
                                                <Button Grid.Column="2" Content="Revenu" Command="{Binding ChoisirRevenuCommand}" Style="{StaticResource SegmentButton}" Margin="4,0,0,0"/>
                                            </Grid>

                                            <!-- Input Fields -->
                                            <TextBlock Text="Intitulé" Foreground="{StaticResource TextSub}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding NouveauTitre, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,14"/>

                                            <TextBlock Text="Montant (€)" Foreground="{StaticResource TextSub}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding NouveauMontantEuros, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,20"/>

                                            <Button Content="➕ Valider la transaction" Command="{Binding AjouterTransactionCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ================= CALENDRIER TEMPLATE ================= -->
                        <DataTemplate DataType="{x:Type vm:CalendrierViewModel}">
                            <StackPanel>
                                <TextBlock Text="Calendrier unifié &amp; Échéances" Foreground="{StaticResource TextMain}" FontSize="26" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock Text="Superposition des rendez-vous et des échéances financières datées (§5.4)." Foreground="{StaticResource TextSub}" FontSize="14" Margin="0,0,0,28"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="360"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Agenda Stream -->
                                    <StackPanel Grid.Column="0">
                                        <ItemsControl ItemsSource="{Binding Evenements}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource GlassCard}" Margin="0,6" Padding="18">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Width="42" Height="42" CornerRadius="12" Background="#28354D" Margin="0,0,16,0">
                                                                <TextBlock Text="📅" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Titre}" Foreground="{StaticResource TextMain}" FontWeight="Bold" FontSize="15"/>
                                                                <TextBlock Text="{Binding Type}" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                            <Border Grid.Column="2" Background="#2E3B52" CornerRadius="8" Padding="10,4" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Statut}" Foreground="{StaticResource TextMain}" FontSize="12" FontWeight="SemiBold"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- Quick Add Appointment Card -->
                                    <Border Grid.Column="2" Style="{StaticResource GlassCard}" VerticalAlignment="Top">
                                        <StackPanel>
                                            <TextBlock Text="📅 Planifier un rendez-vous" Foreground="{StaticResource TextMain}" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                                            <TextBlock Text="Titre du rendez-vous" Foreground="{StaticResource TextSub}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding NouveauRendezvousTitre, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>
                                            <Button Content="Enregistrer au calendrier" Command="{Binding AjouterRendezvousCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ================= NOTES TEMPLATE ================= -->
                        <DataTemplate DataType="{x:Type vm:NotesViewModel}">
                            <StackPanel>
                                <TextBlock Text="Notes libres &amp; Brouillons" Foreground="{StaticResource TextMain}" FontSize="26" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock Text="Brouillon de texte libre sans structure imposée (§5.5)." Foreground="{StaticResource TextSub}" FontSize="14" Margin="0,0,0,28"/>

                                <Border Style="{StaticResource GlassCard}" Margin="0,0,0,28">
                                    <StackPanel>
                                        <TextBlock Text="📝 Rédiger une nouvelle note" Foreground="{StaticResource TextMain}" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                                        <TextBox Text="{Binding NouvelleNoteTexte, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="110" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>
                                        <Button Content="Enregistrer la note" Command="{Binding AjouterNoteCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>

                                <ItemsControl ItemsSource="{Binding Notes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource GlassCard}" Margin="0,4" Padding="16">
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextMain}" FontSize="14" TextWrapping="Wrap"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ================= CORBEILLE TEMPLATE ================= -->
                        <DataTemplate DataType="{x:Type vm:CorbeilleViewModel}">
                            <StackPanel>
                                <TextBlock Text="Corbeille &amp; Suppression" Foreground="{StaticResource TextMain}" FontSize="26" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock Text="Vue des éléments marqués supprime = true. Seule la purge manuelle détruit (§5.6)." Foreground="{StaticResource TextSub}" FontSize="14" Margin="0,0,0,28"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Button Content="🔄 Restaurer l'élément sélectionné" Command="{Binding RestaurerCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,14,0"/>
                                    <Button Content="🗑️ Purger définitivement" Command="{Binding PurgerCommand}" Style="{StaticResource DangerButton}"/>
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding ElementsSupprimes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource GlassCard}" Margin="0,4" Padding="16">
                                                <TextBlock Text="{Binding Titre}" Foreground="{StaticResource TextSub}" FontSize="14" TextDecorations="Strikethrough"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ================= RÉGLAGES TEMPLATE ================= -->
                        <DataTemplate DataType="{x:Type vm:ReglagesViewModel}">
                            <StackPanel>
                                <TextBlock Text="Réglages &amp; Synchronisation" Foreground="{StaticResource TextMain}" FontSize="26" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock Text="Paramétrage du solde de référence et exportation des données (§5.7)." Foreground="{StaticResource TextSub}" FontSize="14" Margin="0,0,0,28"/>

                                <!-- Recalage Solde -->
                                <Border Style="{StaticResource GlassCard}" Margin="0,0,0,28">
                                    <StackPanel>
                                        <TextBlock Text="⚙️ Recalage du solde de référence (€)" Foreground="{StaticResource TextMain}" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                                        <TextBox Text="{Binding NouveauSoldeReferenceEuros, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>
                                        <Button Content="Appliquer le recalage" Command="{Binding RecalerSoldeCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>

                                <!-- Export ZIP -->
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="📦 Exportation locale complète (§5.7)" Foreground="{StaticResource TextMain}" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBlock Text="Produit une archive ZIP sur votre Bureau contenant donnees.json et les pièces jointes, 100% hors-ligne." Foreground="{StaticResource TextSub}" FontSize="13" Margin="0,0,0,18"/>
                                        <Button Content="📦 Générer l'archive ZIP sur le Bureau" Command="{Binding ExporterZipCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding StatutSynchro}" Foreground="{StaticResource AccentSecondary}" FontSize="13" Margin="0,16,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>

                    </ContentControl.Resources>
                </ContentControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
