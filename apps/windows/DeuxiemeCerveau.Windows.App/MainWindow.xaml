<Window x:Class="DeuxiemeCerveau.Windows.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DeuxiemeCerveau.Windows.App.ViewModels"
        Title="Deuxième Cerveau — Spécification v3.1 Complète" Height="860" Width="1380"
        Background="{StaticResource BgCanvas}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR NAVIGATION -->
        <Border Grid.Column="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,1,0">
            <DockPanel Margin="16,24">
                <!-- App Header -->
                <StackPanel DockPanel.Dock="Top" Margin="4,0,0,24">
                    <TextBlock Text="Deuxième Cerveau" Foreground="{StaticResource TextMain}" FontSize="17" FontWeight="Bold"/>
                    <TextBlock Text="Gestion Personnelle Local-First" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Navigation List -->
                <StackPanel DockPanel.Dock="Top">
                    <RadioButton Content="Finances" Command="{Binding NaviguerFinancesCommand}" IsChecked="True" Style="{StaticResource NavTabButton}"/>
                    <RadioButton Content="Budget projeté 12M (§5.1)" Command="{Binding NaviguerBudgetProjeteCommand}" Style="{StaticResource NavTabButton}"/>
                    <RadioButton Content="Envies &amp; Achats (§5.1)" Command="{Binding NaviguerEnviesCommand}" Style="{StaticResource NavTabButton}"/>
                    <RadioButton Content="Calendrier Apple (§5.4)" Command="{Binding NaviguerCalendrierCommand}" Style="{StaticResource NavTabButton}"/>
                    <RadioButton Content="Notes libres (§5.5)" Command="{Binding NaviguerNotesCommand}" Style="{StaticResource NavTabButton}"/>
                    <RadioButton Content="Corbeille (§5.6)" Command="{Binding NaviguerCorbeilleCommand}" Style="{StaticResource NavTabButton}"/>
                    <RadioButton Content="Paramètres (§5.7)" Command="{Binding NaviguerReglagesCommand}" Style="{StaticResource NavTabButton}"/>
                </StackPanel>

                <!-- Status Footer -->
                <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom">
                    <Border Style="{StaticResource CleanCard}" Padding="12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="6" Height="6" Fill="#10B981" Margin="0,0,8,0"/>
                            <TextBlock Text="Base SQLite local-first active" Foreground="{StaticResource TextSub}" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="36">
                <ContentControl Content="{Binding VueCourante}">
                    <ContentControl.Resources>
                        
                        <!-- ================= FINANCES TEMPLATE ================= -->
                        <DataTemplate DataType="{x:Type vm:FinancesViewModel}">
                            <StackPanel>
                                <TextBlock Text="Finances" Foreground="{StaticResource TextMain}" FontSize="24" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="Suivi du solde de référence et enregistrement des transactions (§5.1)" Foreground="{StaticResource TextSub}" FontSize="13" Margin="0,0,0,24"/>

                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource CleanCard}">
                                        <StackPanel>
                                            <TextBlock Text="SOLDE DE RÉFÉRENCE (§3.4)" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding SoldeEurosFormatted}" Foreground="{StaticResource AccentSuccess}" FontSize="26" FontWeight="Bold" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Style="{StaticResource CleanCard}">
                                        <StackPanel>
                                            <TextBlock Text="REVENUS CUMULÉS" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding TotalEntreesFormatted}" Foreground="{StaticResource TextMain}" FontSize="26" FontWeight="Bold" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="4" Style="{StaticResource CleanCard}">
                                        <StackPanel>
                                            <TextBlock Text="DÉPENSES CUMULÉES" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding TotalSortiesFormatted}" Foreground="{StaticResource TextSub}" FontSize="26" FontWeight="Bold" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="340"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBox Text="{Binding RechercheTexte, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                                        <ItemsControl ItemsSource="{Binding Transactions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource CleanCard}" Margin="0,3" Padding="14">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="{Binding Titre}" Foreground="{StaticResource TextMain}" FontWeight="SemiBold" FontSize="14"/>
                                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                                    <Border Background="#161822" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                                                        <TextBlock Text="{Binding Type}" Foreground="{StaticResource TextSub}" FontSize="11"/>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding Statut}" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Text="{Binding MontantCentimes}" Foreground="{StaticResource TextMain}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <Border Grid.Column="2" Style="{StaticResource CleanCard}" VerticalAlignment="Top">
                                        <StackPanel>
                                            <TextBlock Text="Nouvelle transaction" Foreground="{StaticResource TextMain}" FontSize="15" FontWeight="Bold" Margin="0,0,0,16"/>

                                            <TextBlock Text="Type de transaction" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,0,0,6"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Content="Facture" Command="{Binding ChoisirFactureCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,3,0"/>
                                                <Button Grid.Column="1" Content="Paiement" Command="{Binding ChoisirPaiementCommand}" Style="{StaticResource SecondaryButton}" Margin="2,0,2,0"/>
                                                <Button Grid.Column="2" Content="Revenu" Command="{Binding ChoisirRevenuCommand}" Style="{StaticResource SecondaryButton}" Margin="3,0,0,0"/>
                                            </Grid>

                                            <TextBlock Text="Libellé" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding NouveauTitre, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                                            <TextBlock Text="Catégorie (§3.3)" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,0,0,6"/>
                                            <ComboBox ItemsSource="{Binding Categories}" DisplayMemberPath="Nom" SelectedItem="{Binding CategorieSelectionnee, Mode=TwoWay}" Margin="0,0,0,12" Padding="10,8" Background="{StaticResource BgInput}" Foreground="{StaticResource TextMain}"/>

                                            <TextBlock Text="Montant (€)" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding NouveauMontantEuros, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                                            <Button Content="Enregistrer la transaction" Command="{Binding AjouterTransactionCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ================= BUDGET PROJETÉ 12M TEMPLATE ================= -->
                        <DataTemplate DataType="{x:Type vm:BudgetProjeteViewModel}">
                            <StackPanel>
                                <TextBlock Text="Budget projeté (12 mois glissants) (§5.1)" Foreground="{StaticResource TextMain}" FontSize="24" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="Algorithme de projection officielle : solde de référence + cascade mensuelle + mise en évidence des mois déficitaires" Foreground="{StaticResource TextSub}" FontSize="13" Margin="0,0,0,24"/>

                                <ItemsControl ItemsSource="{Binding Projections}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CleanCard}" Margin="0,4" Padding="16">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="180"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding NomMois}" Foreground="{StaticResource TextMain}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="Ouverture" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                                        <TextBlock Text="{Binding SoldeOuvertureFormatted}" Foreground="{StaticResource TextSub}" FontSize="14"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <TextBlock Text="Entrées" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                                        <TextBlock Text="{Binding TotalEntreesFormatted}" Foreground="{StaticResource AccentSuccess}" FontSize="14" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                        <TextBlock Text="Sorties" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                                        <TextBlock Text="{Binding TotalSortiesFormatted}" Foreground="{StaticResource AccentDanger}" FontSize="14" FontWeight="SemiBold"/>
                                                    </StackPanel>

                                                    <Border Grid.Column="4" CornerRadius="6" Padding="12,6" VerticalAlignment="Center" Background="#161822" BorderBrush="{StaticResource BorderLight}" BorderThickness="1">
                                                        <StackPanel HorizontalAlignment="Center">
                                                            <TextBlock Text="Clôture estimée" Foreground="{StaticResource TextMuted}" FontSize="10" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="{Binding SoldeClotureFormatted}" Foreground="{StaticResource TextMain}" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ================= ENVIES & ACHATS TEMPLATE ================= -->
                        <DataTemplate DataType="{x:Type vm:EnviesViewModel}">
                            <StackPanel>
                                <TextBlock Text="Envies &amp; Achats souhaités (§5.1)" Foreground="{StaticResource TextMain}" FontSize="24" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="Liste de souhaits confrontable au budget projeté pour arbitrer les achats non essentiels" Foreground="{StaticResource TextSub}" FontSize="13" Margin="0,0,0,24"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="340"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <ItemsControl ItemsSource="{Binding Envies}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource CleanCard}" Margin="0,3" Padding="14">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="{Binding Titre}" Foreground="{StaticResource TextMain}" FontWeight="SemiBold" FontSize="14"/>
                                                                <TextBlock Text="{Binding Statut}" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Text="{Binding MontantCentimes}" Foreground="{StaticResource TextMain}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <Border Grid.Column="2" Style="{StaticResource CleanCard}" VerticalAlignment="Top">
                                        <StackPanel>
                                            <TextBlock Text="Ajouter une envie d'achat" Foreground="{StaticResource TextMain}" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>
                                            <TextBlock Text="Libellé de l'envie" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding NouvelleEnvieTitre, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                                            <TextBlock Text="Montant estimé (€)" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding NouvelleEnvieMontantEuros, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                                            <Button Content="Enregistrer l'envie" Command="{Binding AjouterEnvieCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ================= CALENDRIER APPLE TEMPLATE ================= -->
                        <DataTemplate DataType="{x:Type vm:CalendrierViewModel}">
                            <StackPanel>
                                <TextBlock Text="Calendrier Style Apple (§5.4)" Foreground="{StaticResource TextMain}" FontSize="24" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="Superposition des rendez-vous et des échéances financières avec grille mensuelle" Foreground="{StaticResource TextSub}" FontSize="13" Margin="0,0,0,20"/>

                                <Border Style="{StaticResource CleanCard}" Margin="0,0,0,20" Padding="16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding MoisCourantTitre}" Foreground="{StaticResource TextMain}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <Button Content="◄ Précédent" Command="{Binding MoisPrecedentCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                                            <Button Content="Aujourd'hui" Command="{Binding AujourdhuiCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                                            <Button Content="Suivant ►" Command="{Binding MoisSuivantCommand}" Style="{StaticResource SecondaryButton}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource CleanCard}" Margin="0,0,0,20" Padding="12">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Filtres catégories : " Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <ItemsControl ItemsSource="{Binding FiltresCategories}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding EstActif, Mode=TwoWay}" Content="{Binding Categorie.Nom}" Foreground="{StaticResource TextMain}" FontSize="12" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="340"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <UniformGrid Columns="7" Margin="0,0,0,8">
                                            <TextBlock Text="LUN" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="MAR" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="MER" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="JEU" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="VEN" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="SAM" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="DIM" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </UniformGrid>

                                        <ItemsControl ItemsSource="{Binding GrilleJours}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="7"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Height="75" Margin="2" CornerRadius="6" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" Padding="6">
                                                        <Grid>
                                                            <TextBlock Text="{Binding JourNumero}" Foreground="{StaticResource TextMain}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                                            <ItemsControl ItemsSource="{Binding Evenements}" VerticalAlignment="Bottom">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="{StaticResource AccentPrimary}" CornerRadius="3" Margin="0,1" Padding="4,1">
                                                                            <TextBlock Text="{Binding Titre}" Foreground="White" FontSize="9" TextTrimming="CharacterEllipsis"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <Border Grid.Column="2" Style="{StaticResource CleanCard}" VerticalAlignment="Top">
                                        <StackPanel>
                                            <TextBlock Text="Planifier un rendez-vous" Foreground="{StaticResource TextMain}" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>
                                            <TextBlock Text="Titre" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding NouveauRendezvousTitre, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                                            <TextBlock Text="Récurrence RRULE (§3.1)" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,0,0,4"/>
                                            <ComboBox SelectedValue="{Binding RecurrenceSelectionnee, Mode=TwoWay}" Margin="0,0,0,16" Padding="10,6" Background="{StaticResource BgInput}" Foreground="{StaticResource TextMain}">
                                                <ComboBoxItem Content="Aucune"/>
                                                <ComboBoxItem Content="Quotidienne"/>
                                                <ComboBoxItem Content="Hebdomadaire"/>
                                                <ComboBoxItem Content="Mensuelle"/>
                                            </ComboBox>

                                            <Button Content="Ajouter au calendrier" Command="{Binding AjouterRendezvousCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ================= NOTES TEMPLATE ================= -->
                        <DataTemplate DataType="{x:Type vm:NotesViewModel}">
                            <StackPanel>
                                <TextBlock Text="Notes" Foreground="{StaticResource TextMain}" FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="Brouillons de texte libre (§5.5)" Foreground="{StaticResource TextSub}" FontSize="13" Margin="0,0,0,24"/>

                                <Border Style="{StaticResource CleanCard}" Margin="0,0,0,24">
                                    <StackPanel>
                                        <TextBlock Text="Nouvelle note" Foreground="{StaticResource TextMain}" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>
                                        <TextBox Text="{Binding NouvelleNoteTexte, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="100" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>
                                        <Button Content="Enregistrer la note" Command="{Binding AjouterNoteCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>

                                <ItemsControl ItemsSource="{Binding Notes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CleanCard}" Margin="0,3" Padding="14">
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextMain}" FontSize="13" TextWrapping="Wrap"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ================= CORBEILLE TEMPLATE ================= -->
                        <DataTemplate DataType="{x:Type vm:CorbeilleViewModel}">
                            <StackPanel>
                                <TextBlock Text="Corbeille" Foreground="{StaticResource TextMain}" FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="Éléments supprimés en attente de purge définitive (§5.6)" Foreground="{StaticResource TextSub}" FontSize="13" Margin="0,0,0,24"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Button Content="Restaurer l'élément" Command="{Binding RestaurerCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"/>
                                    <Button Content="Purger définitivement" Command="{Binding PurgerCommand}" Style="{StaticResource SecondaryButton}"/>
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding ElementsSupprimes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CleanCard}" Margin="0,3" Padding="14">
                                                <TextBlock Text="{Binding Titre}" Foreground="{StaticResource TextMuted}" FontSize="13" TextDecorations="Strikethrough"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ================= PARAMÈTRES TEMPLATE ================= -->
                        <DataTemplate DataType="{x:Type vm:ReglagesViewModel}">
                            <StackPanel>
                                <TextBlock Text="Paramètres &amp; Export/Import (§5.7)" Foreground="{StaticResource TextMain}" FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="Configuration de l'application et gestion des sauvegardes ZIP local-first" Foreground="{StaticResource TextSub}" FontSize="13" Margin="0,0,0,24"/>

                                <Border Style="{StaticResource CleanCard}" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="Solde de référence (§3.4)" Foreground="{StaticResource TextMain}" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>
                                        <TextBox Text="{Binding NouveauSoldeReferenceEuros, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,14"/>
                                        <Button Content="Recaler le solde" Command="{Binding RecalerSoldeCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CleanCard}">
                                    <StackPanel>
                                        <TextBlock Text="Exportation &amp; Importation locale ZIP (§5.7)" Foreground="{StaticResource TextMain}" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBlock Text="Génère ou réimporte une archive ZIP (donnees.json et pièces jointes) 100% hors-ligne sans dépendance serveur." Foreground="{StaticResource TextSub}" FontSize="13" Margin="0,0,0,16"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                            <Button Content="Exporter mes données (ZIP)" Command="{Binding ExporterZipCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,12,0"/>
                                            <Button Content="Importer une archive (ZIP)" Command="{Binding ImporterZipCommand}" Style="{StaticResource SecondaryButton}"/>
                                        </StackPanel>

                                        <CheckBox IsChecked="{Binding RappelExportMensuelActif, Mode=TwoWay}" Content="Activer le rappel mensuel d'exportation (§5.7)" Foreground="{StaticResource TextMain}" FontSize="13" Margin="0,0,0,12"/>

                                        <TextBlock Text="{Binding StatutSynchro}" Foreground="{StaticResource TextSub}" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>

                    </ContentControl.Resources>
                </ContentControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
